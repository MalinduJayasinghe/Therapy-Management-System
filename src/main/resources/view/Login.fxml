<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lk.ijse.therapy_management_system.controller.LoginController"
            prefHeight="580.0" prefWidth="920.0"
            styleClass="root-pane"
            stylesheets="@../css/style.css">

    <HBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <VBox prefWidth="460" styleClass="brand-panel"
              alignment="CENTER" spacing="20">
            <VBox.margin><Insets/></VBox.margin>

            <Label text="🌿" style="-fx-font-size:60px;"/>

            <Label text="Serenity" styleClass="brand-title"/>
            <Label text="Mental Health Therapy Center"
                   styleClass="brand-subtitle" wrapText="true"
                   textAlignment="CENTER"/>

            <Separator prefWidth="200"
                       style="-fx-background-color:#ffffff55; -fx-border-color:#ffffff55;"/>

            <Label text="Healing Minds · Restoring Hope"
                   styleClass="brand-tagline"/>
        </VBox>

        <VBox prefWidth="460" alignment="CENTER"
              styleClass="login-card-container">

            <VBox styleClass="login-card" spacing="0" maxWidth="360"
                  alignment="TOP_CENTER">
                <VBox.margin><Insets top="0"/></VBox.margin>

                <VBox alignment="CENTER" spacing="4"
                      style="-fx-padding:30 30 20 30;">
                    <Label text="Welcome Back" styleClass="login-heading"/>
                    <Label text="Sign in to your account"
                           styleClass="login-subheading"/>
                </VBox>

                <VBox spacing="14" style="-fx-padding:0 30 24 30;">

                    <VBox spacing="5">
                        <Label text="Username" styleClass="field-label"/>
                        <TextField fx:id="txtUsername"
                                   promptText="Enter your username"
                                   styleClass="form-field"/>
                        <Label fx:id="lblUsernameError"
                               styleClass="error-label" visible="false"
                               managed="false"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Password" styleClass="field-label"/>
                        <StackPane>
                            <PasswordField fx:id="txtPassword"
                                           promptText="Enter your password"
                                           styleClass="form-field"/>
                            <TextField fx:id="txtPasswordVisible"
                                       promptText="Enter your password"
                                       styleClass="form-field"
                                       visible="false" managed="false"/>
                            <HBox alignment="CENTER_RIGHT"
                                  style="-fx-padding:0 10 0 0;"
                                  pickOnBounds="false">
                                <Button fx:id="btnTogglePassword"
                                        text="👁"
                                        styleClass="eye-btn"
                                        onAction="#handleTogglePassword"/>
                            </HBox>
                        </StackPane>
                        <Label fx:id="lblPasswordError"
                               styleClass="error-label" visible="false"
                               managed="false"/>
                    </VBox>

                    <Label fx:id="lblGeneralError"
                           styleClass="error-label-center"
                           wrapText="true" textAlignment="CENTER"
                           visible="false" managed="false"/>

                    <Button fx:id="btnLogin" text="Sign In"
                            styleClass="btn-primary"
                            prefWidth="Infinity"
                            defaultButton="true"
                            onAction="#handleLogin"/>

                </VBox>

                <HBox alignment="CENTER"
                      style="-fx-padding:12 0 20 0; -fx-border-color:#e8ecf0 transparent transparent transparent; -fx-border-width:1;">
                    <Label text="Serenity MHT Center © 2025"
                           styleClass="footer-text"/>
                </HBox>

            </VBox>

        </VBox>
    </HBox>
</AnchorPane>
