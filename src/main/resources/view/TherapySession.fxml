<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lk.ijse.therapy_management_system.controller.TherapySessionController"
            stylesheets="@../css/style.css">

    <ScrollPane fitToWidth="true" fitToHeight="true"
                AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
                style="-fx-background-color:transparent; -fx-background:#f0f4f8;">

        <VBox spacing="16" style="-fx-padding:24;">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Therapy Session Scheduling" styleClass="page-title"/>
                    <Label text="Book, reschedule or cancel therapy appointments"
                           styleClass="page-subtitle"/>
                </VBox>
                <TextField fx:id="txtSearch" promptText="🔍  Search sessions…"
                           styleClass="search-field" onKeyReleased="#handleSearch"/>
            </HBox>

            <HBox spacing="16">
                <!-- Form -->
                <VBox styleClass="page-card" spacing="12" prefWidth="360">
                    <VBox spacing="4">
                        <Label text="Session ID" styleClass="field-label"/>
                        <TextField fx:id="txtSessionId" styleClass="form-field"
                                   editable="false" style="-fx-background-color:#e9ecef;"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Patient *" styleClass="field-label"/>
                        <ComboBox fx:id="cmbPatient" styleClass="combo-box" prefWidth="Infinity"/>
                        <Label fx:id="lblPatientError" styleClass="error-label" visible="false" managed="false"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Therapy Program *" styleClass="field-label"/>
                        <ComboBox fx:id="cmbProgram" styleClass="combo-box" prefWidth="Infinity"
                                  onAction="#handleProgramChanged"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Therapist *" styleClass="field-label"/>
                        <ComboBox fx:id="cmbTherapist" styleClass="combo-box" prefWidth="Infinity"/>
                        <Label fx:id="lblTherapistError" styleClass="error-label" visible="false" managed="false"/>
                    </VBox>
                    <HBox spacing="10">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Session Date *" styleClass="field-label"/>
                            <DatePicker fx:id="dpSessionDate" styleClass="date-picker" prefWidth="160"/>
                            <Label fx:id="lblDateError" styleClass="error-label" visible="false" managed="false"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Session Time *" styleClass="field-label"/>
                            <TextField fx:id="txtSessionTime" promptText="HH:MM (e.g. 09:00)"
                                       styleClass="form-field"/>
                            <Label fx:id="lblTimeError" styleClass="error-label" visible="false" managed="false"/>
                        </VBox>
                    </HBox>
                    <VBox spacing="4">
                        <Label text="Status" styleClass="field-label"/>
                        <ComboBox fx:id="cmbStatus" styleClass="combo-box" prefWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Notes" styleClass="field-label"/>
                        <TextArea fx:id="txtNotes" styleClass="text-area" prefRowCount="3" wrapText="true"/>
                    </VBox>

                    <HBox spacing="8" style="-fx-padding:8 0 0 0;">
                        <Button text="📅 Book"     styleClass="btn-primary"   onAction="#handleBook"   prefWidth="80"/>
                        <Button text="✏ Update"    styleClass="btn-warning"   onAction="#handleUpdate" prefWidth="80"/>
                        <Button text="❌ Cancel"    styleClass="btn-danger"    onAction="#handleCancel" prefWidth="80"/>
                        <Button text="🔄 Clear"     styleClass="btn-secondary" onAction="#handleClear"  prefWidth="80"/>
                    </HBox>
                    <Label fx:id="lblStatus" text="" styleClass="page-subtitle" wrapText="true"/>
                </VBox>

                <!-- Table -->
                <VBox styleClass="page-card" spacing="12" HBox.hgrow="ALWAYS">
                    <Label text="Session Records" styleClass="page-title" style="-fx-font-size:15px;"/>
                    <TableView fx:id="tblSessions" VBox.vgrow="ALWAYS"
                               styleClass="table-view" onMouseClicked="#handleTableClick">
                        <columns>
                            <TableColumn fx:id="colId"           text="ID"         prefWidth="70"/>
                            <TableColumn fx:id="colPatientName"  text="Patient"    prefWidth="140"/>
                            <TableColumn fx:id="colTherapist"    text="Therapist"  prefWidth="140"/>
                            <TableColumn fx:id="colProgram"      text="Program"    prefWidth="160"/>
                            <TableColumn fx:id="colDate"         text="Date"       prefWidth="100"/>
                            <TableColumn fx:id="colTime"         text="Time"       prefWidth="70"/>
                            <TableColumn fx:id="colStatus"       text="Status"     prefWidth="100"/>
                        </columns>
                        <placeholder><Label text="No sessions found." styleClass="page-subtitle"/></placeholder>
                    </TableView>
                </VBox>
            </HBox>
        </VBox>
    </ScrollPane>
</AnchorPane>
